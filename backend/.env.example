# ============================================================
#  VidyaMitra — .env.example
#  Copy this file to .env and fill in your values
#  NEVER commit your actual .env file to Git!
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/vidyamitra
# MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vidyamitra

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── File Uploads ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ── AI APIs (needed from Phase 3 onwards) ────────────────────
OPENAI_API_KEY=sk-...
# OR
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloud Storage (needed for production) ────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=vidyamitra-resumes
# AWS_REGION=us-east-1

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
